{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback regarding the application.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The feedback message text.",
          "maxLength": 1000
        },
        "createdAt": {
          "type": "object",
          "description": "Timestamp when the feedback was submitted",
          "$ref": "timestamp"
        }
      },
      "required": ["text", "createdAt"]
    }
  },
  "firestore": {
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Stores user feedback submissions."
    }
  }
}
